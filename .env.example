# Copy this file to .env and edit the paths to match your machine.
# .env is gitignored; each collaborator sets their own.

# Absolute path to the Dropbox folder that holds data/ and output/
# (sibling of /raw and /clean at the data level).
PROCUREMENT_CHILE_DB=/Users/YOUR_USERNAME/Dropbox/procurement-chile-db

# Absolute path to the local code/ directory.
# Optional: if not set, config.py auto-derives this from its own location,
# which works whenever you run scripts inside the repo. Set this only if
# you need to override (e.g. running from an unusual entrypoint).
# PROCUREMENT_CHILE_CODE=/Users/YOUR_USERNAME/path/to/procurement-chile-local/code
